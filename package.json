{
  "name": "twitter-fixer",
  "version": "1.0.0",
  "description": "Discord bot that fixes Twitter/X and Bluesky embeds",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check src/ tests/",
    "format": "prettier --write src/ tests/",
    "db:generate": "drizzle-kit generate"
  },
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.1.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }}
